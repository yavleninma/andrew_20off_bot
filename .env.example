TELEGRAM_BOT_TOKEN=123456:abc
BOT_ACCESS_PASSWORD=change_me_123

# Optional: pre-authorize chats comma-separated.
ALLOWED_CHAT_IDS=

# simulated | sandbox | tinkoff
SOURCE_MODE=sandbox
SIMULATED_EMIT_MODE=always
TINKOFF_TOKEN=
# Leave empty = poll ALL accounts the token has access to.
# Or specify one/multiple comma-separated IDs to limit: 123,456,789
TINKOFF_ACCOUNT_ID=
TINKOFF_LOOKBACK_MINUTES=1440
TINKOFF_SKIP_HISTORY_ON_START=false

DB_PATH=./data/app.db
POLL_SECONDS=15
DAILY_DIGEST_CRON=0 21 * * *

# Fallback size of the source account. Used only when live startup snapshot is unavailable.
MAIN_ACCOUNT_VALUE=1000000
# Size of the mirror account where you repeat trades manually.
MIRROR_ACCOUNT_VALUE=100000
COMMISSION_RATE=0.2

# debug | info | warn | error
LOG_LEVEL=info

# Optional for production image pinning in compose.
# Usually set by CD pipeline during deploy.
BOT_IMAGE=
