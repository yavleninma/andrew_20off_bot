{
  "name": "andrew_20off_bot",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "tsx src/smoke.ts",
    "start": "node dist/index.js",
    "docker:dev": "docker compose --profile dev up --build",
    "docker:prod": "docker compose --profile prod up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f bot"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Telegram signal assistant MVP for manual trade mirroring",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "node-cron": "^4.2.1",
    "telegraf": "^4.16.3",
    "tinkoff-invest-api": "^7.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
